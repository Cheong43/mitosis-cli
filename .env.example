# ============================================================
# Mempedia CodeCLI — 环境变量样例
# 复制此文件为 .env 并填入真实值
# ============================================================

# ------------------------------------------------------------
# LLM 主推理模型
# ------------------------------------------------------------
# OpenAI 或 OpenAI-compatible 接口
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# 显式覆盖模型上下文窗口（可选；不填则按模型名内置映射推断）
# MODEL_CONTEXT_LIMIT=128000

# ------------------------------------------------------------
# Anthropic 格式接口（设置后自动优先使用）
# ------------------------------------------------------------
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# ------------------------------------------------------------
# 文档兼容 / 透传模型配置（当前 TS 代码未直接读取，但 README 已公开）
# ------------------------------------------------------------
# 向量检索模型（可选）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Coding Plan 别名（可选）
CODING_PLAN_BASE_URL=
CODING_PLAN_MODEL=

# ------------------------------------------------------------
# 独立记忆 LLM（可选，不填则复用主模型）
# ------------------------------------------------------------
MEMORY_API_KEY=
MEMORY_BASE_URL=
MEMORY_MODEL=

# ------------------------------------------------------------
# 鉴权 / Gateway（可选，与后端对接时使用）
# ------------------------------------------------------------
# 主服务 HMAC 签名
HMAC_ACCESS_KEY=
HMAC_SECRET_KEY=

# 记忆服务 HMAC 签名
MEMORY_HMAC_ACCESS_KEY=
MEMORY_HMAC_SECRET_KEY=

# Gateway API Key（与 HMAC 二选一）
GATEWAY_API_KEY=
MEMORY_GATEWAY_API_KEY=

# ------------------------------------------------------------
# GitHub（用于 repo 相关工具）
# ------------------------------------------------------------
GITHUB_TOKEN=

# ------------------------------------------------------------
# 记忆行为调节（均有默认值，通常不需改动）
# ------------------------------------------------------------
# 从对话提取记忆的最大字符数（默认 12000）
MEMORY_EXTRACTION_MAX_CHARS=12000

# 是否启用自动关联 (1=开, 0=关, 默认 1)
MEMORY_AUTO_LINK_ENABLED=1

# 自动关联时最多处理节点数（默认 6）
MEMORY_AUTO_LINK_MAX_NODES=6

# 自动关联候选搜索数量上限（默认 5）
MEMORY_AUTO_LINK_LIMIT=5

# 关系相似度最低得分阈值（默认 1.2）
MEMORY_RELATION_MIN_SCORE=1.2

# 关系候选搜索数量（默认 3）
MEMORY_RELATION_SEARCH_LIMIT=3

# 每个节点最大关系数（默认 6）
MEMORY_RELATION_MAX=6

# 对话结束后是否自动排队保存记忆 (1=开, 0=关, 默认 1)
AUTO_QUEUE_MEMORY_SAVE=1

# ------------------------------------------------------------
# 超时（毫秒，均有默认值）
# ------------------------------------------------------------
# 请求超时（README 文档兼容项）
MEMPEDIA_REQUEST_TIMEOUT_MS=0

# 整体记忆任务超时（默认 180000 = 3 分钟）
MEMORY_TASK_TIMEOUT_MS=180000

# 记忆提取子任务超时（默认 90000 = 1.5 分钟）
MEMORY_EXTRACT_TIMEOUT_MS=90000

# 单次记忆保存动作超时（默认 20000 = 20 秒）
MEMORY_SAVE_ACTION_TIMEOUT_MS=20000

# Agent LLM 调用超时（默认 120000 = 2 分钟）
AGENT_LLM_TIMEOUT_MS=120000

# Web 抓取超时（默认 15000 = 15 秒）
MEMPEDIA_WEB_TIMEOUT_MS=15000

# Web 抓取超时别名（默认与 MEMPEDIA_WEB_TIMEOUT_MS 等价）
MITOSIS_WEB_TIMEOUT_MS=15000

# Shell 命令执行超时（默认 15000 = 15 秒）
MEMPEDIA_SHELL_TIMEOUT_MS=15000

# Rust transport IPC 超时（默认 20000 = 20 秒）
MEMPEDIA_TRANSPORT_TIMEOUT_MS=20000

# ------------------------------------------------------------
# ReAct 多分支推理（均有默认值）
# ------------------------------------------------------------
# 最大分支深度（默认 2）
REACT_BRANCH_MAX_DEPTH=2

# 每层最大分支数（默认 3）
REACT_BRANCH_MAX_WIDTH=3

# 每个分支最大步骤数（默认 8）
REACT_BRANCH_MAX_STEPS=8

# 最多完成分支数（默认 4）
REACT_BRANCH_MAX_COMPLETED=4

# 并发分支数（默认 3）
REACT_BRANCH_CONCURRENCY=3

# Planner 温度（默认 0.1）
PLANNER_TEMPERATURE=0.1

# 最终回答温度（默认 0.3）
RESPONSE_TEMPERATURE=0.3

# ------------------------------------------------------------
# Beam Search ReAct 模式（与分支模式二选一）
# ------------------------------------------------------------
# 启用 beam search 模式 (1=开, 0=关, 默认 0)
REACT_BEAM_SEARCH_ENABLED=0

# Beam 宽度 — 每步保留的候选路径数（默认 3）
REACT_BEAM_WIDTH=3

# 最大搜索深度（默认 5）
REACT_BEAM_MAX_DEPTH=5

# 每条路径每步扩展的候选数量（默认 3）
REACT_BEAM_EXPANSION_FACTOR=3

# ------------------------------------------------------------
# Mempedia 路径 / 配置
# ------------------------------------------------------------
# 覆盖项目根目录路径（不填则自动检测）
# MITOSIS_PROJECT_ROOT=
# MEMPEDIA_PROJECT_ROOT=

# 覆盖 Rust 二进制路径（按优先级 MEMPEDIA_BINARY > MEMPEDIA_BINARY_PATH）
# MEMPEDIA_BINARY=
# MEMPEDIA_BINARY_PATH=

# 文档导入每块最大字符数（默认 8000）
MEMPEDIA_CHUNK_CHARS=8000

# UI 服务端口（默认 7878）
MEMPEDIA_UI_PORT=7878

# ------------------------------------------------------------
# 调试 / 性能
# ------------------------------------------------------------
# 是否打印 Agent 性能计时日志 (1=开, 0=关, 默认 1)
AGENT_PERF=1

# planner 回放集成测试：提示词文件列表（逗号分隔，可选）
PLANNER_REPLAY_PROMPTS=

# planner 回放集成测试：迭代次数（默认 2）
PLANNER_REPLAY_ITERATIONS=2
