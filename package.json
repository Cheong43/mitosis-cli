{
  "name": "mitosis-cli",
  "version": "1.0.0",
  "description": "MitosisCLI — independent branching ReAct agent with local-only storage",
  "main": "dist/index.js",
  "scripts": {
    "start": "node --loader ts-node/esm src/index.tsx",
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.tsx",
    "test": "npm run build && node --test dist/runtime/agent/*.test.js dist/agent/*.test.js dist/mempedia/*.test.js",
    "test:budget": "npm run build && node --test dist/agent/contextBudget.test.js",
    "test:budget:live": "npm run build && node --test dist/agent/contextBudget.integration.test.js",
    "test:planner:live": "npm run build && node --test dist/agent/plannerReplay.integration.test.js",
    "test:session": "npm run build && node --test dist/agent/sessionCompressor.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "ai": "^6.0.141",
    "dotenv": "^16.4.7",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "json5": "^2.2.3",
    "react": "^18.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ink": "^2.0.3",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
